  "fv_formula": {
    "inputs": ["home_rating (0-100)", "away_rating (0-100)", "home_rest_days", "away_rest_days"],
    "formula": "fv = sigmoid((home_rating - away_rating + 3.2 + (home_rest - away_rest)*0.5) * fv_coeff)",
    "sigmoid": "1 / (1 + exp(-z))",
    "clamp": "[0.10, 0.90]",
    "home_court_advantage": 3.2,
    "rest_coeff": 0.5,
    "example": "OKC(84) vs Wizards(37): z = (84-37+3.2)*0.05 = 2.51 → fv = 92.5%"
  },

  "gates": {
    "E1_fv_min": "fv >= 0.65 (strong favorite threshold)",
    "E2_edge_min": "fv - kalshi_yes_price >= 0.03 (3¢ underpricing)",
    "E3_sharp_min": "sharp_line >= 0.68 (confirms books agree)",
    "E4_timing": "mins_until_game <= 90 (pre-game only)",
    "E5_volume": "volume >= 3000",
    "E6_spread": "spread <= 0.04"
  },

  "sizing": {
    "method": "tiered_units",
    "tiers": {
      "edge >= 0.10": "2.0 units = $6.00",
      "edge >= 0.08": "1.5 units = $4.50",
      "edge < 0.08":  "1.0 unit  = $3.00"
    },
    "contracts": "floor(dollar_amt / kalshi_yes_price)",
    "direction": "always YES (home team is the strong favorite)"
  },

  "exit": {
    "rule": "hold_to_settlement",
    "early_exit": false
