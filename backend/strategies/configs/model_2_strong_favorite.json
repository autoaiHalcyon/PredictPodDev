{
    "model_id": "model_2",
    "display_name": "Model 2: Strong Favorite Value",
    "description": "Strong Favorite Value model. Exploits favorite-longshot bias — heavy favorites are systematically underpriced by public. Enter only in last 30min before tip. Always bet YES. Hold to settlement.",
    "enabled": true,

    "starting_capital": 300.0,
    "currency": "USD",

    "entry_rules": {
        "fair_value_min": 0.72,
        "min_edge_threshold": 0.06,
        "sharp_line_min": 0.68,
        "time_until_game_max_minutes": 30,
        "volume_min": 5000,
        "spread_max": 0.04,
        "direction": "YES"
    },

    "exit_rules": {
        "hold_to_settlement": true,
        "no_early_exit": true
    },

    "position_sizing": {
        "method": "tiered",
        "unit_size_dollars": 3.0,
        "tiers": {
            "edge_gte_010": 2.0,
            "edge_gte_008": 1.5,
            "edge_gte_006": 1.0
        },
        "max_position_pct": 0.025,
        "max_position_dollars": 7.50
    },

    "fair_value_params": {
        "home_court_advantage_points": 3.2,
        "rest_adj_per_day": 0.5,
        "point_to_prob_coeff": 0.028,
        "fair_value_clamp_lo": 0.10,
        "fair_value_clamp_hi": 0.90
    },

    "risk_limits": {
        "max_daily_loss_pct": 0.10,
        "max_daily_loss_dollars": 30.0,
        "max_open_trades": 10,
        "max_drawdown_pct": 0.15
    },

    "filters": {
        "allowed_leagues": ["NBA", "NCAA_M", "NCAA_W"],
        "max_spread_pct": 0.04,
        "min_volume_24h": 5000
    },

    "trim_rules": {
        "enable_trim": false
    },

    "circuit_breakers": {
        "pause_on_consecutive_losses": 8,
        "pause_duration_seconds": 3600,
        "pause_on_drawdown_pct": 0.10,
        "auto_resume": true
    },

    "metrics_targets": {
        "win_rate_target": 0.56,
        "avg_edge_target_min": 0.06,
        "avg_edge_target_max": 0.08,
        "roi_target": 0.06,
        "sharpe_target": 1.0,
        "max_drawdown_limit": 0.15,
        "min_trades_for_evaluation": 50
    }
}
