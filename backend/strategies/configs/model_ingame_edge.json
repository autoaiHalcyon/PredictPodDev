{
    "model_id": "ingame_edge_trader",
    "display_name": "In-Game Edge Trader",
    "description": "Consolidated in-game model replacing the redundant A/B/C trio. Trades live games only. Placeholder until Master Rules 5-model system is implemented.",
    "enabled": true,

    "starting_capital": 10000.0,
    "currency": "USD",

    "entry_rules": {
        "min_edge_threshold": 0.05,
        "min_signal_score": 55,
        "min_persistence_ticks": 3,
        "max_entries_per_game": 4,
        "cooldown_seconds": 120,
        "volatility_regime_allowed": ["low", "medium"]
    },

    "exit_rules": {
        "edge_compression_exit_threshold": 0.02,
        "profit_target_pct": 0.15,
        "stop_loss_pct": 0.08,
        "hard_adverse_stop_pct": 0.05,
        "hard_adverse_stop_seconds": 120,
        "time_based_exit_seconds": 600
    },

    "position_sizing": {
        "kelly_fraction": 0.5,
        "max_position_pct": 0.05
    },

    "risk_limits": {
        "max_daily_loss_pct": 0.06,
        "max_exposure_pct": 0.20,
        "max_trades_per_hour": 10,
        "max_trades_per_day": 20,
        "max_open_trades": 6,
        "max_trades_per_game": 4,
        "max_drawdown_pct": 0.12
    },

    "filters": {
        "min_liquidity_contracts": 50,
        "max_spread_pct": 0.04,
        "min_game_progress": 0.10,
        "max_game_progress": 0.95,
        "allowed_leagues": ["NBA", "NCAA_M", "NCAA_W"]
    },

    "trim_rules": {
        "enable_trim": true,
        "trim_at_profit_pct": 0.10,
        "trim_size_pct": 0.50,
        "trim_on_edge_decay": true,
        "edge_decay_threshold": 0.025
    },

    "circuit_breakers": {
        "pause_on_consecutive_losses": 4,
        "pause_duration_seconds": 600,
        "pause_on_drawdown_pct": 0.06,
        "auto_resume": true
    }
}
